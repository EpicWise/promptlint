{
  "name": "@ceoepicwise/promptlint",
  "version": "1.0.0",
  "private": false,
  "description": "A linter for LLM prompts. Scores your prompt across 7 dimensions, flags technique gaps for your use case, and generates an improved version.",
  "bin": {
    "promptlint": "bin/install.mjs"
  },
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "files": [
    "bin/",
    ".claude-plugin/",
    "commands/",
    "skills/",
    "evals/",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "promptlint",
    "prompt-engineering",
    "prompt-evaluation",
    "prompt-linter",
    "claude-code",
    "claude-code-plugin",
    "rag",
    "multi-source-rag",
    "agentic",
    "llm",
    "best-practices"
  ],
  "author": {
    "name": "EpicWise",
    "email": "ankit.verma@epicwise.io",
    "url": "https://github.com/EpicWise"
  },
  "homepage": "https://github.com/EpicWise/promptlint",
  "repository": {
    "type": "git",
